# Pinned Docker image versions — committed to git.
# Update this file when upgrading stack components (bump version + PR).
# These are NOT secrets — do not add to .gitignore.

# Observability stack
DOCKER_IMG_GRAFANA=grafana/grafana:12.3
DOCKER_IMG_OTEL_COLLECTOR=otel/opentelemetry-collector-contrib:0.147.0
DOCKER_IMG_LOKI=grafana/loki:3.5.12
DOCKER_IMG_TEMPO=grafana/tempo:2.10.2
DOCKER_IMG_MIMIR=grafana/mimir:3.0.4

# AI tooling
DOCKER_IMG_GRAFANA_MCP=mcp/grafana:latest
DOCKER_IMG_OLLAMA=ollama/ollama:0.18.0

# Data
DOCKER_IMG_POSTGRES=postgres:18
DOCKER_IMG_ADMINER=adminer:5.4.2

# Messaging
DOCKER_IMG_KAFKA=confluentinc/cp-kafka:8.1.0
DOCKER_IMG_AKHQ=tchiotludo/akhq:0.26.0

# Python base image for KEEPER service Dockerfiles
IMG_PYTHON_BASE=python:3.14-slim
