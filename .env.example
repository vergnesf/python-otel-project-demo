# Environment Variables — secrets and local overrides only.
# Copy this file to .env and fill in the values below.
#
# Docker image versions are in versions.env (committed to git — no copy needed).
# Override any image here if needed: DOCKER_IMG_GRAFANA=grafana/grafana:custom

# Optional: private Docker registry prefix (e.g. registry.example.com/)
# DOCKER_REGISTRY=

# Grafana Service Account Token (required for agent layer MCP access)
GRAFANA_SERVICE_ACCOUNT_TOKEN=replace_with_your_token

# PostgreSQL password (used by docker-compose-db.yml and docker-compose-apps.yml)
POSTGRES_PASSWORD=yourpassword

